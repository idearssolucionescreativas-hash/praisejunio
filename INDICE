// ──────────── HELPERS ────────────
function fmt(n) { return n ? '$' + n.toLocaleString('es-CO') : '—'; }
function fmtK(n) { return n >= 1000 ? '$' + (n/1000).toFixed(0) + 'K' : '$' + n; }
function cprClass(v) { if (!v) return ''; if (v < 2000) return 'cpr-good'; if (v < 4000) return 'cpr-mid'; return 'cpr-bad'; }
function statusBadge(s) {
  const map = { active:'badge-active', paused:'badge-paused', scaling:'badge-scaling', underperform:'badge-underperform', testing:'badge-testing' };
  const label = { active:'🟢 Activo', paused:'❌ Pausado', scaling:'💥 Escalando', underperform:'🔴 Bajo rend.', testing:'🔥 Test' };
  return `<span class="badge ${map[s]||''}">${label[s]||s}</span>`;
}
function scoreLabel(cpr, results) {
  if (!results) return ['D','score-d'];
  if (cpr < 2000 && results >= 5) return ['A','score-a'];
  if (cpr < 3000) return ['B','score-b'];
  if (cpr < 5000) return ['C','score-c'];
  return ['D','score-d'];
}

// ──────────── ADSET TABLE ────────────
function renderAdsets(filter) {
  const tbody = document.getElementById('adsetBody');
  const maxRes = Math.max(...DATA.adsets.map(a => a.results));
  const rows = DATA.adsets.filter(a => filter === 'all' || a.status === filter);
  tbody.innerHTML = rows.map(a => {
    const pct = maxRes ? Math.round(a.results / maxRes * 100) : 0;
    const color = a.status === 'scaling' ? '#f59e0b' : a.status === 'active' ? '#4f46e5' : '#9ca3af';
    const shortName = a.name.replace(/^[^\s]+\s/, '').replace(/\| CBO \| VTA-Wpp \|/, '|').trim();
    return `<tr data-status="${a.status}">
      <td>${statusBadge(a.status)}</td>
      <td><div class="adset-name" title="${a.name}">${shortName}</div></td>
      <td class="num">${fmtK(a.spend)}</td>
      <td class="num"><strong>${a.results}</strong></td>
      <td class="num">${(a.reach/1000).toFixed(1)}K</td>
      <td class="num ${cprClass(a.cpr)}">${a.cpr ? fmtK(a.cpr) : '—'}</td>
      <td class="num">${a.ctr ? a.ctr.toFixed(2)+'%' : '—'}</td>
      <td class="num">${a.conv ? a.conv+'%' : '—'}</td>
      <td style="min-width:80px">
        <div style="font-size:11px;color:var(--muted);margin-bottom:2px">${pct}%</div>
        <div class="bar-mini"><div class="bar-mini-fill" style="width:${pct}%;background:${color}"></div></div>
      </td>
    </tr>`;
  }).join('');
  // Totals row
  const tSpend = rows.reduce((s,a)=>s+a.spend,0);
  const tRes   = rows.reduce((s,a)=>s+a.results,0);
  const tReach = rows.reduce((s,a)=>s+a.reach,0);
  const totalAll = DATA.adsets.length;
  const label = filter === 'all'
    ? `<span class="total-label">Total: ${totalAll} conjuntos testeados</span>`
    : `<span class="total-label">${rows.length} de ${totalAll} conjuntos</span>`;
  document.getElementById('adsetFoot').innerHTML = `<tr>
    <td>—</td>
    <td>${label}</td>
    <td class="num">$${tSpend.toLocaleString('es-CO')}</td>
    <td class="num">${tRes}</td>
    <td class="num">${(tReach/1000).toFixed(1)}K</td>
    <td class="num">—</td><td class="num">—</td><td class="num">—</td><td>—</td>
  </tr>`;
}
renderAdsets('all');

function filterAdsets(f, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('on'));
