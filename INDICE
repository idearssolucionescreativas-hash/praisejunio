// ──────────── CHARTS ────────────
window._chartsBuilt = false;
window._adsChartBuilt = false;

function buildCharts() {
  window._chartsBuilt = true;
  const labels = DATA.daily.map(d => d.date.slice(5)); // MM-DD
  const spends = DATA.daily.map(d => d.spend);
  const results = DATA.daily.map(d => d.results);
  const cprs = DATA.daily.map(d => d.cpr);
  const ctrs = DATA.daily.map(d => d.ctr);

  // Daily spend + results
  new Chart(document.getElementById('chartDaily'), {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { type: 'bar', label: 'Gasto COP', data: spends, backgroundColor: 'rgba(79,70,229,0.25)', borderColor: 'rgba(79,70,229,0.8)', borderWidth: 1.5, borderRadius: 4, yAxisID: 'y' },
        { type: 'line', label: 'Conversaciones', data: results, borderColor: '#0ea5e9', backgroundColor: 'rgba(14,165,233,0.15)', borderWidth: 2.5, pointRadius: 3, pointBackgroundColor: '#0ea5e9', tension: 0.35, fill: true, yAxisID: 'y2' }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { font: { size: 11 }, boxWidth: 12 } }, tooltip: { mode: 'index', intersect: false } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 10 }, maxTicksLimit: 14 } },
        y: { position: 'left', grid: { color: '#f3f4f6' }, ticks: { font: { size: 10 }, callback: v => '$'+(v/1000).toFixed(0)+'K' } },
        y2: { position: 'right', grid: { display: false }, ticks: { font: { size: 10 }, stepSize: 2 } }
      }
    }
  });

  // Status donut
  const statusCount = {};
  DATA.adsets.forEach(a => { statusCount[a.status] = (statusCount[a.status]||0) + 1; });
  const statusLabels = { active:'🟢 Activos', paused:'❌ Pausados', scaling:'💥 Escalando', underperform:'🔴 Bajo rend.', testing:'🔥 Testing' };
  const statusColors = { active:'#16a34a', paused:'#dc2626', scaling:'#f59e0b', underperform:'#db2777', testing:'#7c3aed' };
    new Chart(document.getElementById('chartStatus'), {
    type: 'doughnut',
    data: {
      labels: Object.keys(statusCount).map(k => statusLabels[k]||k),
      datasets: [{ data: Object.values(statusCount), backgroundColor: Object.keys(statusCount).map(k => statusColors[k]||'#9ca3af'), borderWidth: 2, borderColor: '#fff' }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { font: { size: 11 }, boxWidth: 12, padding: 12 } } },
      cutout: '62%'
    }
  });

  // CPR line
  new Chart(document.getElementById('chartCPR'), {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'CPR (COP)',
        data: cprs,
        borderColor: '#ea580c',
        backgroundColor: 'rgba(234,88,12,0.1)',
        borderWidth: 2, pointRadius: 3, tension: 0.3, fill: true
      }, {
        label: 'Meta $3.000',
        data: labels.map(() => 3000),
        borderColor: '#16a34a', borderDash: [5,4], borderWidth: 1.5, pointRadius: 0
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { font: { size: 11 }, boxWidth: 12 } }, tooltip: { callbacks: { label: ctx => '$'+ctx.parsed.y.toLocaleString('es-CO') } } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 10 }, maxTicksLimit: 10 } },
        y: { grid: { color: '#f3f4f6' }, ticks: { font: { size: 10 }, callback: v => '$'+(v/1000).toFixed(0)+'K' } }
      }
    }
  });

  // CTR line
  new Chart(document.getElementById('chartCTR'), {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'CTR %',
        data: ctrs,
        borderColor: '#7c3aed',
        backgroundColor: 'rgba(124,58,237,0.1)',
        borderWidth: 2, pointRadius: 3, tension: 0.35, fill: true
      }, {
        label: 'Referencia 1%',
        data: labels.map(() => 1),
        borderColor: '#16a34a', borderDash: [5,4], borderWidth: 1.5, pointRadius: 0
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { font: { size: 11 }, boxWidth: 12 } } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 10 }, maxTicksLimit: 10 } },
        y: { grid: { color: '#f3f4f6' }, ticks: { font: { size: 10 }, callback: v => v+'%' } }
      }
    }
  });
}

function buildAdsChart() {
  window._adsChartBuilt = true;
  const top = DATA.ads.filter(a => a.results > 0).slice(0, 8);
  new Chart(document.getElementById('chartAds'), {
    type: 'bar',
    data: {
      labels: top.map(a => a.name),
      datasets: [
        { label: 'Resultados', data: top.map(a => a.results), backgroundColor: '#4f46e5', borderRadius: 6 },
        { label: 'CPR (÷100)', data: top.map(a => Math.round(a.cpr/100)), backgroundColor: '#f59e0b', borderRadius: 6 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { font: { size: 11 }, boxWidth: 12 } }, tooltip: { callbacks: {
        label: ctx => ctx.datasetIndex === 0 ? ctx.parsed.y + ' conv.' : '$' + (ctx.parsed.y * 100).toLocaleString() + ' CPR'
      }}},
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 11 } } },
        y: { grid: { color: '#f3f4f6' }, ticks: { font: { size: 10 } } }
      }
    }
  });
}

// Build overview charts on load
setTimeout(buildCharts, 100);
</script>
